discard """
  description: "A `ProcDecl` body is part of a new scope"
  argument: "c"
"""
(Module
  (ProcDecl (Ident "test1") (UnitTy) (Params)
    (Exprs
      (Decl (Ident "local") (IntVal 100))
      (Return)))

  (ProcDecl (Ident "test2") (UnitTy) (Params)
    (Exprs
      (Decl (Ident "local") (IntVal 100))
      (Return))))
